{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "startCommand": "npm start",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 10,
    "restartPolicyMaxRetries": 5
  },
  "environments": {
    "production": {
      "PORT": 3002,
      "NODE_ENV": "production"
    },
    "development": {
      "PORT": 3002,
      "NODE_ENV": "development"
    }
  }
}
